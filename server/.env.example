PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/aarambhh
JWT_SECRET=your_jwt_secret_here

# Optional public app URL used in WhatsApp messages, e.g. https://aarambhh.com
PUBLIC_APP_URL=https://aarambhh.com

# Optional WhatsApp webhook that receives saved audit leads and their message payload
WHATSAPP_WEBHOOK_URL=https://your-whatsapp-provider.example/webhook

# Gmail SMTP Email Config for quote routes
# Get your app password from Google Account -> Security -> 2-Step Verification -> App Passwords
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
